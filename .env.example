# --- LLM API Configuration ---
# Recommendation: Get a free API key from Groq (https://console.groq.com/) 
# for ultra-fast response times.
LLM_API_KEY=your_groq_api_key_here
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
MODEL_NAME=llama-3.1-70b-versatile

# --- Wake Word Configuration ---
# Get your free access key from Picovoice Console (https://console.picovoice.ai/)
PICOVOICE_API_KEY=your_picovoice_key_here

# --- Paths ---
# You will need to download whisper.cpp and Piper TTS models
# and place them in the models/ directory or update these paths.
# PIPER_PATH=piper
# WHISPER_PATH=./models/whisper/main
